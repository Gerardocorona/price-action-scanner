//@version=6
indicator("Rebote Tendencial Simple v6", shorttitle="RTS v6", overlay=true, max_labels_count=500)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CONFIGURACIÓN
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
emaLen      = input.int(20, "EMA de tendencia", minval=1)
showEMA     = input.bool(true, "Mostrar EMA")
showMarks   = input.bool(true, "Mostrar marcas")
showSignals = input.bool(true, "Mostrar señales")
showStats   = input.bool(true, "Mostrar estadísticas", group="Visual")

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// FUNCIONES BÁSICAS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
body(_i) => math.abs(close[_i] - open[_i])
isBull(_i) => close[_i] > open[_i]
isBear(_i) => close[_i] < open[_i]

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TENDENCIA
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ema20 = ta.ema(close, emaLen)
trendUp   = close > ema20 and ema20 > ema20[1]
trendDown = close < ema20 and ema20 < ema20[1]

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PATRÓN A: ENVOLVENTE
// [2] = contra-tendencia | [1] = envolvente body > body[2]
// [0] = confirmación rompe high[1] o low[1]
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool envCall = isBear(2) and isBull(1) and body(1) > body(2) and isBull(0) and close > high[1]
bool envPut  = isBull(2) and isBear(1) and body(1) > body(2) and isBear(0) and close < low[1]

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PATRÓN B: TWO-ERASE
// [2] = contra-tendencia | [1]+[0] = dos velas combinadas borran [2]
// [0] = confirmación rompe high[1] o low[1]
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool teCall = isBear(2) and isBull(1) and isBull(0) and (body(1) + body(0)) > body(2) and close > high[1]
bool tePut  = isBull(2) and isBear(1) and isBear(0) and (body(1) + body(0)) > body(2) and close < low[1]

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// SEÑALES FINALES
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
bool signalCall = barstate.isconfirmed and trendUp   and (envCall or teCall)
bool signalPut  = barstate.isconfirmed and trendDown and (envPut  or tePut)

bool isEnvCall  = envCall and not teCall
bool isTeCall   = teCall  and not envCall
bool isBothCall = envCall and teCall
bool isEnvPut   = envPut  and not tePut
bool isTePut    = tePut   and not envPut
bool isBothPut  = envPut  and tePut

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// CONTADORES
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
var int cnt_env_call  = 0
var int cnt_te_call   = 0
var int cnt_both_call = 0
var int cnt_env_put   = 0
var int cnt_te_put    = 0
var int cnt_both_put  = 0

if isEnvCall  and trendUp   and barstate.isconfirmed
    cnt_env_call  += 1
if isTeCall   and trendUp   and barstate.isconfirmed
    cnt_te_call   += 1
if isBothCall and trendUp   and barstate.isconfirmed
    cnt_both_call += 1
if isEnvPut   and trendDown and barstate.isconfirmed
    cnt_env_put   += 1
if isTePut    and trendDown and barstate.isconfirmed
    cnt_te_put    += 1
if isBothPut  and trendDown and barstate.isconfirmed
    cnt_both_put  += 1

int total_call = cnt_env_call + cnt_te_call + cnt_both_call
int total_put  = cnt_env_put  + cnt_te_put  + cnt_both_put
int total_all  = total_call + total_put
int total_env_only = cnt_env_call + cnt_env_put
int total_te_only  = cnt_te_call  + cnt_te_put
int total_both     = cnt_both_call + cnt_both_put
float pct_env  = total_all > 0 ? total_env_only / total_all * 100 : 0
float pct_te   = total_all > 0 ? total_te_only  / total_all * 100 : 0
float pct_both = total_all > 0 ? total_both     / total_all * 100 : 0

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// TABLA ESTADÍSTICAS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
var table statsTable = table.new(position.top_right, 4, 6, bgcolor=color.new(color.black, 20), border_width=1, border_color=color.gray)

if barstate.islast and showStats
    table.cell(statsTable, 0, 0, "PATRÓN",     text_color=color.white,  text_size=size.small, bgcolor=color.new(color.gray, 30))
    table.cell(statsTable, 1, 0, "CALL",        text_color=color.lime,   text_size=size.small, bgcolor=color.new(color.gray, 30))
    table.cell(statsTable, 2, 0, "PUT",         text_color=color.red,    text_size=size.small, bgcolor=color.new(color.gray, 30))
    table.cell(statsTable, 3, 0, "%",           text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.gray, 30))
    table.cell(statsTable, 0, 1, "Envolvente",  text_color=color.aqua,   text_size=size.small)
    table.cell(statsTable, 1, 1, str.tostring(cnt_env_call),  text_color=color.white, text_size=size.small)
    table.cell(statsTable, 2, 1, str.tostring(cnt_env_put),   text_color=color.white, text_size=size.small)
    table.cell(statsTable, 3, 1, str.tostring(pct_env, "#.0") + "%",  text_color=color.aqua,   text_size=size.small)
    table.cell(statsTable, 0, 2, "Two-Erase",  text_color=color.purple, text_size=size.small)
    table.cell(statsTable, 1, 2, str.tostring(cnt_te_call),   text_color=color.white, text_size=size.small)
    table.cell(statsTable, 2, 2, str.tostring(cnt_te_put),    text_color=color.white, text_size=size.small)
    table.cell(statsTable, 3, 2, str.tostring(pct_te, "#.0") + "%",  text_color=color.purple, text_size=size.small)
    table.cell(statsTable, 0, 3, "Ambos E+T",  text_color=color.green,  text_size=size.small)
    table.cell(statsTable, 1, 3, str.tostring(cnt_both_call), text_color=color.white, text_size=size.small)
    table.cell(statsTable, 2, 3, str.tostring(cnt_both_put),  text_color=color.white, text_size=size.small)
    table.cell(statsTable, 3, 3, str.tostring(pct_both, "#.0") + "%", text_color=color.green,  text_size=size.small)
    table.cell(statsTable, 0, 4, "", text_size=size.tiny)
    table.cell(statsTable, 1, 4, "", text_size=size.tiny)
    table.cell(statsTable, 2, 4, "", text_size=size.tiny)
    table.cell(statsTable, 3, 4, "", text_size=size.tiny)
    table.cell(statsTable, 0, 5, "TOTAL",       text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.gray, 30))
    table.cell(statsTable, 1, 5, str.tostring(total_call),    text_color=color.lime,   text_size=size.small, bgcolor=color.new(color.gray, 30))
    table.cell(statsTable, 2, 5, str.tostring(total_put),     text_color=color.red,    text_size=size.small, bgcolor=color.new(color.gray, 30))
    table.cell(statsTable, 3, 5, str.tostring(total_all),     text_color=color.yellow, text_size=size.small, bgcolor=color.new(color.gray, 30))

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// VISUAL
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
plot(showEMA ? ema20 : na, "EMA 20", color=color.yellow, linewidth=2)
barcolor(signalCall ? color.lime : signalPut ? color.red : na)

plotshape(showMarks and signalCall, title="Ref CALL", style=shape.circle, location=location.belowbar, offset=-2, color=color.orange, size=size.tiny, text="R")
plotshape(showMarks and (isEnvCall or isBothCall), title="Env CALL", style=shape.circle, location=location.belowbar, offset=-1, color=color.aqua, size=size.tiny, text="E")
plotshape(showMarks and isTeCall, title="TE CALL", style=shape.circle, location=location.belowbar, offset=-1, color=color.purple, size=size.tiny, text="T")

plotshape(showMarks and signalPut, title="Ref PUT", style=shape.circle, location=location.abovebar, offset=-2, color=color.orange, size=size.tiny, text="R")
plotshape(showMarks and (isEnvPut or isBothPut), title="Env PUT", style=shape.circle, location=location.abovebar, offset=-1, color=color.aqua, size=size.tiny, text="E")
plotshape(showMarks and isTePut, title="TE PUT", style=shape.circle, location=location.abovebar, offset=-1, color=color.purple, size=size.tiny, text="T")

plotshape(showSignals and isEnvCall, title="CALL Env", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, size=size.small, text="CALL")
plotshape(showSignals and isTeCall, title="CALL TE", style=shape.labelup, location=location.belowbar, color=color.teal, textcolor=color.white, size=size.small, text="CALL\nTE")
plotshape(showSignals and isBothCall, title="CALL E+T", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, size=size.small, text="CALL\nE+T")

plotshape(showSignals and isEnvPut, title="PUT Env", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.small, text="PUT")
plotshape(showSignals and isTePut, title="PUT TE", style=shape.labeldown, location=location.abovebar, color=color.maroon, textcolor=color.white, size=size.small, text="PUT\nTE")
plotshape(showSignals and isBothPut, title="PUT E+T", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.small, text="PUT\nE+T")

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ALERTAS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
alertcondition(signalCall, "RTS: CALL SPX 0DTE", '{"ticker":"SPX","signal":"CALL"}')
alertcondition(signalPut,  "RTS: PUT SPX 0DTE",  '{"ticker":"SPX","signal":"PUT"}')